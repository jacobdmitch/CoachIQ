{
  "name": "coachiq",
  "version": "1.0.0",
  "description": "Tablet-native AI coaching assistant for lacrosse coaches",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "cd frontend && npm install && npm run build",
    "migrate": "node run-all-migrations.js",
    "seed": "node scripts/seed-demo.js",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "node --experimental-test-module-mocks --test --test-reporter=spec 'tests/services/**/*.test.js' 'tests/routes/**/*.test.js'",
    "test:frontend": "cd frontend && npm test -- --watchAll=false --passWithNoTests"
  },
  "keywords": [
    "lacrosse",
    "coaching",
    "ai",
    "tablet"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "pg": "^8.13.3",
    "sharp": "^0.33.4",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": "22"
  }
}
